---
import { getEntry, render } from "astro:content";
import ClientDocLayout from "../../../layouts/ClientDocLayout.astro";
import { client, clientLabel, zenDocs } from "../../../lib/clients/zen";

const entry = await getEntry("clients", "zen/fulfillment-loop");

if (!entry) {
  throw new Error("Missing Zen fulfillment loop content entry.");
}

const { Content } = await render(entry);
---

<ClientDocLayout
  title={entry.data.title}
  description={entry.data.description}
  client={client}
  clientLabel={clientLabel}
  currentPath={Astro.url.pathname}
  docs={zenDocs}
>
  <p class="client__eyebrow">Zen Life · Loop 1</p>
  <h2 class="client__title">{entry.data.title}</h2>
  <p class="client__lead">
    Phase 1 fulfillment — from patient sign-up and UHID through diagnostic order lifecycle to Zen report delivery.
  </p>

  <div class="client__prose">
    <Content />
  </div>
</ClientDocLayout>
