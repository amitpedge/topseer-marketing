---
import ClientDocLayout from "../../../layouts/ClientDocLayout.astro";

const client = "zen";
const clientLabel = "Zen";

const docs = [
  { href: `/clients/${client}/doc-1/`, label: "Doc 1" },
  { href: `/clients/${client}/doc-2/`, label: "Doc 2" },
];
---

<ClientDocLayout
  title="Doc 2"
  description="Doc 2 for Zen."
  client={client}
  clientLabel={clientLabel}
  currentPath={Astro.url.pathname}
  docs={docs}
>
  <p class="client__eyebrow">Doc 2</p>
  <h2 class="client__title">Doc 2</h2>
  <p class="client__lead">Placeholder content — replace with Zen documentation.</p>

  <div class="client__prose">
    <p>
      This page is ready for your second Zen deliverable. Add sections, diagrams, or specs here as
      Markdown or Astro content.
    </p>
  </div>
</ClientDocLayout>
