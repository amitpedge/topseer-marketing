---
import ClientDocLayout from "../../../layouts/ClientDocLayout.astro";
import { client, clientLabel, zenDocs } from "../../../lib/clients/zen";

const doc = zenDocs[1];
---

<ClientDocLayout
  title={doc.label}
  description={doc.description}
  client={client}
  clientLabel={clientLabel}
  currentPath={Astro.url.pathname}
  docs={zenDocs}
>
  <p class="client__eyebrow">{doc.label}</p>
  <h2 class="client__title">{doc.label}</h2>
  <p class="client__lead">Placeholder content — replace with Zen documentation.</p>

  <div class="client__prose">
    <p>
      This page is ready for your second Zen deliverable. Add sections, diagrams, or specs here as
      Markdown or Astro content.
    </p>
  </div>
</ClientDocLayout>
