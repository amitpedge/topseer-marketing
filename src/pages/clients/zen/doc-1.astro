---
import { getEntry, render } from "astro:content";
import ClientDocLayout from "../../../layouts/ClientDocLayout.astro";
import { client, clientLabel, zenDocs } from "../../../lib/clients/zen";

const entry = await getEntry("clients", "zen/client-blueprint");

if (!entry) {
  throw new Error("Missing Zen product blueprint content entry.");
}

const { Content } = await render(entry);
---

<ClientDocLayout
  title={entry.data.title}
  description={entry.data.description}
  client={client}
  clientLabel={clientLabel}
  currentPath={Astro.url.pathname}
  docs={zenDocs}
>
  <p class="client__eyebrow">Zen Life · Product</p>
  <h2 class="client__title">{entry.data.title}</h2>
  <p class="client__lead">
    Product vision, loops, phased delivery, and the decision register for Zen Life stakeholders.
  </p>

  <div class="client__prose">
    <Content />
  </div>
</ClientDocLayout>
