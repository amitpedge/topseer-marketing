---
import ClientDocLayout from "../../../layouts/ClientDocLayout.astro";

const client = "zen";
const clientLabel = "Zen";

const docs = [
  { href: `/clients/${client}/doc-1/`, label: "Doc 1" },
  { href: `/clients/${client}/doc-2/`, label: "Doc 2" },
];
---

<ClientDocLayout
  title="Doc 1"
  description="Doc 1 for Zen."
  client={client}
  clientLabel={clientLabel}
  currentPath={Astro.url.pathname}
  docs={docs}
>
  <p class="client__eyebrow">Doc 1</p>
  <h2 class="client__title">Doc 1</h2>
  <p class="client__lead">Placeholder content — replace with Zen documentation.</p>

  <div class="client__prose">
    <p>
      This page is ready for your first Zen deliverable. Add sections, diagrams, or specs here as
      Markdown or Astro content.
    </p>
  </div>
</ClientDocLayout>
