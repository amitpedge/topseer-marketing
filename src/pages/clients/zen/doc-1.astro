---
import { getEntry, render } from "astro:content";
import ClientDocLayout from "../../../layouts/ClientDocLayout.astro";
import { client, clientLabel, zenDocs } from "../../../lib/clients/zen";

const entry = await getEntry("clients", "zen/entity-model");

if (!entry) {
  throw new Error("Missing Zen entity model content entry.");
}

const { Content } = await render(entry);
---

<ClientDocLayout
  title={entry.data.title}
  description={entry.data.description}
  client={client}
  clientLabel={clientLabel}
  currentPath={Astro.url.pathname}
  docs={zenDocs}
>
  <p class="client__eyebrow">Zenlife · Phase 1</p>
  <h2 class="client__title">{entry.data.title}</h2>
  <p class="client__lead">
    Finalized entities, relationships, and shorthand formulae. Approved terminology as of project
    scoping (July 2026).
  </p>

  <div class="client__prose">
    <Content />
  </div>
</ClientDocLayout>
