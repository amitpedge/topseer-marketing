---
import { getEntry, render } from "astro:content";
import BlueprintArchitectureDiagram from "../../../components/clients/zen/BlueprintArchitectureDiagram.astro";
import BlueprintClinicalReviewDiagram from "../../../components/clients/zen/BlueprintClinicalReviewDiagram.astro";
import BlueprintLoopsDiagram from "../../../components/clients/zen/BlueprintLoopsDiagram.astro";
import BlueprintPhasesDiagram from "../../../components/clients/zen/BlueprintPhasesDiagram.astro";
import ClientDocLayout from "../../../layouts/ClientDocLayout.astro";
import { client, clientLabel, zenDocs } from "../../../lib/clients/zen";

const [partA, partB, partC, partD, partE, partF, partG, partH] = await Promise.all([
  getEntry("clients", "zen/client-blueprint-a"),
  getEntry("clients", "zen/client-blueprint-b"),
  getEntry("clients", "zen/client-blueprint-c"),
  getEntry("clients", "zen/client-blueprint-d"),
  getEntry("clients", "zen/client-blueprint-e"),
  getEntry("clients", "zen/client-blueprint-f"),
  getEntry("clients", "zen/client-blueprint-g"),
  getEntry("clients", "zen/client-blueprint-h"),
]);

if (!partA || !partB || !partC || !partD || !partE || !partF || !partG || !partH) {
  throw new Error("Missing Zen product blueprint content entries.");
}

const [
  { Content: ContentA },
  { Content: ContentB },
  { Content: ContentC },
  { Content: ContentD },
  { Content: ContentE },
  { Content: ContentF },
  { Content: ContentG },
  { Content: ContentH },
] = await Promise.all([
  render(partA),
  render(partB),
  render(partC),
  render(partD),
  render(partE),
  render(partF),
  render(partG),
  render(partH),
]);
---

<ClientDocLayout
  title={partA.data.title}
  description={partA.data.description}
  client={client}
  clientLabel={clientLabel}
  currentPath={Astro.url.pathname}
  docs={zenDocs}
>
  <p class="client__eyebrow">Zen Life · Product</p>
  <h2 class="client__title">{partA.data.title}</h2>
  <p class="client__lead">
    Product vision, loops, phased delivery, and the decision register for Zen Life stakeholders.
  </p>

  <div class="client__prose">
    <ContentA />
    <BlueprintLoopsDiagram />
    <ContentB />
    <BlueprintPhasesDiagram />
    <ContentC />
    <ContentD />
    <BlueprintArchitectureDiagram />
    <ContentE />
    <BlueprintClinicalReviewDiagram />
    <ContentF />
    <ContentG />
    <ContentH />
  </div>
</ClientDocLayout>
