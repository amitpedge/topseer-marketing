---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import { formatBlogDate, getPostUrl, getPublishedPosts } from "../../lib/blog";

const posts = await getPublishedPosts();
---

<MarketingLayout
  title="Blog"
  description="Perspectives on enterprise AI agents, LLM economics, and production delivery from Topseer."
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow eyebrow--light">Blog</p>
      <h1 class="display display--light">Ideas for teams shipping <em>AI in production</em></h1>
      <p class="lead lead--light">
        Notes on agent economics, platform design, and the shift from pilots to governed deployments.
      </p>
    </div>
  </section>

  <section class="section page-body page-body--cream">
    <div class="shell">
      {
        posts.length === 0 ? (
          <p class="blog-empty">No posts yet. Check back soon.</p>
        ) : (
          <ul class="blog-list">
            {posts.map((post) => (
              <li>
                <article class="blog-card">
                  <p class="blog-card__meta">
                    <time datetime={post.data.date.toISOString()}>{formatBlogDate(post.data.date)}</time>
                    <span aria-hidden="true">·</span>
                    <span>{post.data.author}</span>
                  </p>
                  <h2 class="blog-card__title">
                    <a href={getPostUrl(post)}>{post.data.title}</a>
                  </h2>
                  <p class="blog-card__desc">{post.data.description}</p>
                  {
                    post.data.tags.length > 0 && (
                      <ul class="blog-tags" aria-label="Tags">
                        {post.data.tags.map((tag) => (
                          <li>{tag}</li>
                        ))}
                      </ul>
                    )
                  }
                  <a class="blog-card__link" href={getPostUrl(post)}>
                    Read article →
                  </a>
                </article>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>
</MarketingLayout>
