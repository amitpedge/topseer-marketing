---
import MarketingLayout from "../layouts/MarketingLayout.astro";
---

<MarketingLayout
  title="About"
  description="Topseer Tech Private Limited — deep technical expertise in generative AI for enterprise transformation."
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow eyebrow--light">About</p>
      <h1 class="display display--light">AI expertise for enterprises that need to <em>ship</em></h1>
      <p class="lead">
        Topseer teaches companies how to adopt generative AI — and delivers pre-cooked agents on a
        platform built for production, not pilots.
      </p>
    </div>
  </section>

  <section class="section page-body page-body--cream">
    <div class="shell prose">
      <h2>What we do</h2>
      <p>
        Topseer combines deep generative-AI engineering with enterprise delivery. We help
        organisations move from stalled experiments to governed, version-pinned agents that run
        against real systems and real policies.
      </p>

      <h2>How we work</h2>
      <ul>
        <li>Authoritative and precise — restraint over hype.</li>
        <li>Pre-cooked agents, not blank-slate chatbot projects.</li>
        <li>Frozen releases your compliance team can reason about.</li>
        <li>Platform-first — connectors, governance, and observability shared across agents.</li>
      </ul>

      <h2>Legal entity</h2>
      <p>Topseer Tech Private Limited</p>
    </div>
  </section>
</MarketingLayout>
