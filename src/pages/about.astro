---
import MarketingLayout from "../layouts/MarketingLayout.astro";
---

<MarketingLayout
  title="About"
  description="Topseer Tech Private Limited — last mile intelligence in enterprise AI. We convert raw LLM capability into governed agents that run in production."
>
  <section class="page-hero">
    <div class="shell">
      <p class="eyebrow eyebrow--light">About</p>
      <h1 class="display display--light">
        Last mile intelligence<br aria-hidden="true" />
        for <em>enterprise AI</em>
      </h1>
      <p class="lead">
        Topseer converts raw LLM intelligence into agents your business can actually run — on a
        governed platform built for production, not pilots.
      </p>
    </div>
  </section>

  <section class="section page-body page-body--cream">
    <div class="shell prose">
      <h2>What we do</h2>
      <p>
        Topseer combines deep generative-AI engineering with enterprise delivery. We help
        organisations close the last mile between model capability and business outcomes — governed
        agents wired into ERP, CRM, HRIS, and the workflows your teams already use.
      </p>

      <h2>How we work</h2>
      <ul>
        <li>Authoritative and precise — restraint over hype.</li>
        <li>Production agents from the Agent Pantry, not blank-slate chatbot projects.</li>
        <li>Pinned releases your compliance team can reason about.</li>
        <li>Platform-first — connectors, governance, and observability shared across agents.</li>
      </ul>

      <h2>Legal entity</h2>
      <p>Topseer Tech Private Limited</p>
    </div>
  </section>
</MarketingLayout>
