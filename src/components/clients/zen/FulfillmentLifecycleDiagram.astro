---
/** Loop 1 — diagnostic order state machine */
---

<figure class="client-flow-diagram" aria-labelledby="fulfillment-lifecycle-title">
  <figcaption id="fulfillment-lifecycle-title" class="client-flow-diagram__caption">
    Diagnostic order lifecycle — happy path and exception exits
  </figcaption>
  <svg viewBox="0 0 920 280" fill="none" xmlns="http://www.w3.org/2000/svg" role="img">
    <defs>
      <marker id="fl-arrow" markerWidth="8" markerHeight="8" refX="6" refY="4" orient="auto">
        <path d="M0 0 L8 4 L0 8 Z" fill="#5E7C7B" />
      </marker>
      <marker id="fl-arrow-rust" markerWidth="8" markerHeight="8" refX="6" refY="4" orient="auto">
        <path d="M0 0 L8 4 L0 8 Z" fill="#C8613A" />
      </marker>
    </defs>

    <text x="16" y="28" fill="#5E7C7B" font-family="Barlow, sans-serif" font-size="11" font-weight="700" letter-spacing="1.5">HAPPY PATH</text>

    <rect x="16" y="44" width="72" height="44" rx="10" fill="#E6EDEC" stroke="#DED9CC" />
    <text x="52" y="71" text-anchor="middle" fill="#1F3A3D" font-family="JetBrains Mono, monospace" font-size="10" font-weight="500">paid</text>

    <line x1="88" y1="66" x2="112" y2="66" stroke="#5E7C7B" stroke-width="2" marker-end="url(#fl-arrow)" />

    <rect x="112" y="44" width="84" height="44" rx="10" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="154" y="71" text-anchor="middle" fill="#1F3A3D" font-family="JetBrains Mono, monospace" font-size="10" font-weight="500">booked</text>

    <line x1="196" y1="66" x2="220" y2="66" stroke="#5E7C7B" stroke-width="2" marker-end="url(#fl-arrow)" />

    <rect x="220" y="44" width="96" height="44" rx="10" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="268" y="71" text-anchor="middle" fill="#1F3A3D" font-family="JetBrains Mono, monospace" font-size="10" font-weight="500">confirmed</text>

    <line x1="316" y1="66" x2="340" y2="66" stroke="#5E7C7B" stroke-width="2" marker-end="url(#fl-arrow)" />

    <rect x="340" y="44" width="108" height="44" rx="10" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="394" y="71" text-anchor="middle" fill="#1F3A3D" font-family="JetBrains Mono, monospace" font-size="10" font-weight="500">in_progress</text>

    <line x1="448" y1="66" x2="472" y2="66" stroke="#5E7C7B" stroke-width="2" marker-end="url(#fl-arrow)" />

    <rect x="472" y="44" width="132" height="44" rx="10" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="538" y="71" text-anchor="middle" fill="#1F3A3D" font-family="JetBrains Mono, monospace" font-size="10" font-weight="500">completed_at_lab</text>

    <line x1="604" y1="66" x2="628" y2="66" stroke="#5E7C7B" stroke-width="2" marker-end="url(#fl-arrow)" />

    <rect x="628" y="44" width="132" height="44" rx="10" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="694" y="71" text-anchor="middle" fill="#1F3A3D" font-family="JetBrains Mono, monospace" font-size="10" font-weight="500">reports_received</text>

    <line x1="760" y1="66" x2="784" y2="66" stroke="#5E7C7B" stroke-width="2" marker-end="url(#fl-arrow)" />

    <rect x="784" y="44" width="120" height="44" rx="10" fill="#1F3A3D" />
    <text x="844" y="71" text-anchor="middle" fill="#F7F0DD" font-family="JetBrains Mono, monospace" font-size="10" font-weight="600">delivered</text>

    <rect x="784" y="104" width="120" height="36" rx="8" fill="#E6EDEC" stroke="#DED9CC" />
    <text x="844" y="127" text-anchor="middle" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="10" font-weight="600">Loop 1 complete</text>

    <text x="16" y="178" fill="#C8613A" font-family="Barlow, sans-serif" font-size="11" font-weight="700" letter-spacing="1.5">EXCEPTION PATH · POLICY O4</text>

    <path d="M154 88 L154 148" stroke="#C8613A" stroke-width="1.5" stroke-dasharray="4 3" marker-end="url(#fl-arrow-rust)" />
    <path d="M268 88 L268 148" stroke="#C8613A" stroke-width="1.5" stroke-dasharray="4 3" marker-end="url(#fl-arrow-rust)" />

    <rect x="112" y="148" width="96" height="44" rx="10" fill="#FFFFFF" stroke="#C8613A" stroke-width="1.25" />
    <text x="160" y="175" text-anchor="middle" fill="#C8613A" font-family="JetBrains Mono, monospace" font-size="10" font-weight="500">cancelled</text>

    <line x1="208" y1="170" x2="248" y2="170" stroke="#C8613A" stroke-width="1.5" marker-end="url(#fl-arrow-rust)" />

    <rect x="248" y="148" width="96" height="44" rx="10" fill="#FFFFFF" stroke="#C8613A" stroke-width="1.25" />
    <text x="296" y="175" text-anchor="middle" fill="#C8613A" font-family="JetBrains Mono, monospace" font-size="10" font-weight="500">refunded</text>

    <rect x="16" y="214" width="888" height="52" rx="10" fill="#F7F0DD" stroke="#DED9CC" />
    <text x="32" y="238" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="11" font-weight="700">Lab partner staff</text>
    <text x="32" y="254" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="11">Confirm booking · check in · submit Zen report</text>
    <text x="480" y="238" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="11" font-weight="700">Ops</text>
    <text x="480" y="254" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="11">Monitor SLA · support · chase overdue reports</text>
    <text x="760" y="238" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="11" font-weight="700">Patient</text>
    <text x="760" y="254" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="11">Book · view status · receive report</text>
  </svg>
</figure>
