---
/** Notification timeline aligned to order states */
---

<figure class="client-flow-diagram client-flow-diagram--large" aria-labelledby="fulfillment-notifications-title">
  <figcaption id="fulfillment-notifications-title" class="client-flow-diagram__caption">
    Notifications — illustrative patient and internal touchpoints
  </figcaption>
  <svg viewBox="0 0 920 300" fill="none" xmlns="http://www.w3.org/2000/svg" role="img">
    <line x1="120" y1="40" x2="120" y2="260" stroke="#DED9CC" stroke-width="2" />

    <circle cx="120" cy="56" r="8" fill="#B87333" />
    <rect x="148" y="36" width="740" height="40" rx="8" fill="#E6EDEC" stroke="#DED9CC" />
    <text x="164" y="54" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="11" font-weight="700">Profile created</text>
    <text x="164" y="68" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="10">Welcome / UHID confirmation (optional)</text>

    <circle cx="120" cy="96" r="8" fill="#1F3A3D" />
    <rect x="148" y="76" width="740" height="40" rx="8" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="164" y="94" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="11" font-weight="700">→ booked</text>
