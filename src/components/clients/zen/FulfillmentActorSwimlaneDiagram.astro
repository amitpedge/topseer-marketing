---
/** Actor swimlane across order states */
---

<figure class="client-flow-diagram client-flow-diagram--large" aria-labelledby="fulfillment-swimlane-title">
  <figcaption id="fulfillment-swimlane-title" class="client-flow-diagram__caption">
    Actor swimlane — primary actions by order state
  </figcaption>
  <svg viewBox="0 0 920 420" fill="none" xmlns="http://www.w3.org/2000/svg" role="img">
    <text x="120" y="28" fill="#5E7C7B" font-family="Barlow, sans-serif" font-size="11" font-weight="700" letter-spacing="1.2">ACTOR</text>
    <text x="300" y="28" text-anchor="middle" fill="#5E7C7B" font-family="JetBrains Mono, monospace" font-size="10">booked</text>
    <text x="420" y="28" text-anchor="middle" fill="#5E7C7B" font-family="JetBrains Mono, monospace" font-size="10">confirmed</text>
    <text x="540" y="28" text-anchor="middle" fill="#5E7C7B" font-family="JetBrains Mono, monospace" font-size="10">in_progress</text>
    <text x="660" y="28" text-anchor="middle" fill="#5E7C7B" font-family="JetBrains Mono, monospace" font-size="10">completed_at_lab</text>
    <text x="780" y="28" text-anchor="middle" fill="#5E7C7B" font-family="JetBrains Mono, monospace" font-size="10">delivered</text>

    <line x1="220" y1="16" x2="220" y2="392" stroke="#DED9CC" stroke-width="1" />
