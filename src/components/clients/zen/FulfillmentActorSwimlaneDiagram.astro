    <line x1="720" y1="16" x2="720" y2="392" stroke="#DED9CC" stroke-width="1" />

    <rect x="16" y="44" width="188" height="72" rx="10" fill="#F7F0DD" stroke="#DED9CC" />
    <text x="110" y="72" text-anchor="middle" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="12" font-weight="700">Patient</text>
    <text x="110" y="92" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="10">Book · view · receive report</text>

    <rect x="240" y="52" width="100" height="56" rx="8" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="290" y="76" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="9">View · reschedule · cancel</text>
    <rect x="360" y="52" width="100" height="56" rx="8" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="410" y="76" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="9">Reminders · view status</text>
    <rect x="480" y="52" width="100" height="56" rx="8" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="530" y="76" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="9">In progress at lab</text>
    <rect x="600" y="52" width="100" height="56" rx="8" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="650" y="76" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="9">Awaiting report</text>
