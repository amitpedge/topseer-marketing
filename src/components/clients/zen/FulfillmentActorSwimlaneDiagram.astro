    <rect x="720" y="140" width="168" height="56" rx="8" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="804" y="164" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="9">Support access issues</text>

    <rect x="16" y="220" width="188" height="72" rx="10" fill="#FFFFFF" stroke="#B87333" stroke-width="1.25" />
    <text x="110" y="248" text-anchor="middle" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="12" font-weight="700">Lab partner staff</text>
    <text x="110" y="268" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="10">Confirm · check-in · submit report</text>

