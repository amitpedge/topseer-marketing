    <text x="410" y="262" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="8">→ confirmed</text>
    <rect x="480" y="228" width="100" height="56" rx="8" fill="#F7F0DD" stroke="#B87333" />
    <text x="530" y="246" text-anchor="middle" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="9" font-weight="600">Check in patient</text>
