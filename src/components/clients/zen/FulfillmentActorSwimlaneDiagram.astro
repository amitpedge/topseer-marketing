    <rect x="240" y="140" width="100" height="56" rx="8" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="290" y="164" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="9">Confirm booking sent</text>
