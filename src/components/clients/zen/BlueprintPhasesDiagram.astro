---
/** Product blueprint — phased delivery roadmap */
---

<figure class="client-flow-diagram" aria-labelledby="blueprint-phases-title">
  <figcaption id="blueprint-phases-title" class="client-flow-diagram__caption">
    Phased delivery — loop by loop, AI entering at Phase 2
  </figcaption>
  <svg viewBox="0 0 920 260" fill="none" xmlns="http://www.w3.org/2000/svg" role="img">
    <defs>
      <marker id="bp-arrow" markerWidth="8" markerHeight="8" refX="6" refY="4" orient="auto">
        <path d="M0 0 L8 4 L0 8 Z" fill="#5E7C7B" />
      </marker>
    </defs>

    <text x="16" y="28" fill="#5E7C7B" font-family="Barlow, sans-serif" font-size="11" font-weight="700" letter-spacing="1.5">PHASES 1–5 · CORE PRODUCT</text>

    <rect x="16" y="40" width="132" height="118" rx="10" fill="#1F3A3D" />
    <text x="82" y="64" text-anchor="middle" fill="#B87333" font-family="Barlow, sans-serif" font-size="10" font-weight="700">PHASE 1</text>
    <text x="82" y="84" text-anchor="middle" fill="#F7F0DD" font-family="Barlow, sans-serif" font-size="11" font-weight="700">Fulfillment</text>
    <text x="82" y="104" text-anchor="middle" fill="#F7F0DD" font-family="Barlow, sans-serif" font-size="10" opacity="0.8">Non-AI</text>
    <text x="82" y="128" text-anchor="middle" fill="#F7F0DD" font-family="Barlow, sans-serif" font-size="9" opacity="0.7">Book · pay · test</text>
    <text x="82" y="142" text-anchor="middle" fill="#F7F0DD" font-family="Barlow, sans-serif" font-size="9" opacity="0.7">Zen report in system</text>

    <line x1="148" y1="99" x2="168" y2="99" stroke="#5E7C7B" stroke-width="2" marker-end="url(#bp-arrow)" />

    <rect x="168" y="40" width="132" height="118" rx="10" fill="#FFFFFF" stroke="#B87333" stroke-width="1.25" />
    <text x="234" y="64" text-anchor="middle" fill="#B87333" font-family="Barlow, sans-serif" font-size="10" font-weight="700">PHASE 2</text>
    <text x="234" y="84" text-anchor="middle" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="11" font-weight="700">Clinical plan</text>
    <text x="234" y="104" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="10">Human + AI</text>
    <text x="234" y="128" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="9">Physician publishes</text>
    <text x="234" y="142" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="9">Zen health plan</text>

    <line x1="300" y1="99" x2="320" y2="99" stroke="#5E7C7B" stroke-width="2" marker-end="url(#bp-arrow)" />

    <rect x="320" y="40" width="132" height="118" rx="10" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="386" y="64" text-anchor="middle" fill="#B87333" font-family="Barlow, sans-serif" font-size="10" font-weight="700">PHASE 3</text>
    <text x="386" y="84" text-anchor="middle" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="11" font-weight="700">Graph + chat</text>
    <text x="386" y="104" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="10">AI</text>
    <text x="386" y="128" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="9">Knowledge graph live</text>
    <text x="386" y="142" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="9">Grounded chat</text>

    <line x1="452" y1="99" x2="472" y2="99" stroke="#5E7C7B" stroke-width="2" marker-end="url(#bp-arrow)" />

    <rect x="472" y="40" width="132" height="118" rx="10" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="538" y="64" text-anchor="middle" fill="#B87333" font-family="Barlow, sans-serif" font-size="10" font-weight="700">PHASE 4</text>
    <text x="538" y="84" text-anchor="middle" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="11" font-weight="700">Adherence</text>
    <text x="538" y="104" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="10">AI + Patient</text>
    <text x="538" y="128" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="9">Track progress</text>
    <text x="538" y="142" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="9">Nudges · retests</text>

    <line x1="604" y1="99" x2="624" y2="99" stroke="#5E7C7B" stroke-width="2" marker-end="url(#bp-arrow)" />

    <rect x="624" y="40" width="132" height="118" rx="10" fill="#E6EDEC" stroke="#5E7C7B" />
    <text x="690" y="64" text-anchor="middle" fill="#B87333" font-family="Barlow, sans-serif" font-size="10" font-weight="700">PHASE 5</text>
    <text x="690" y="84" text-anchor="middle" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="11" font-weight="700">Enrichment</text>
    <text x="690" y="104" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="10">Autonomous AI</text>
    <text x="690" y="128" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="9">Other report upload</text>
    <text x="690" y="142" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="9">Graph always-on</text>

    <text x="16" y="188" fill="#B87333" font-family="Barlow, sans-serif" font-size="11" font-weight="700" letter-spacing="1.5">PHASE 6+ · SCALE</text>

    <rect x="16" y="200" width="888" height="48" rx="10" fill="#F7F0DD" stroke="#DED9CC" />
    <text x="32" y="222" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="11" font-weight="600">Multi-modality</text>
    <text x="32" y="238" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="10">Voice · video · DICOM · wearables · partner portal · mobile · family accounts</text>
  </svg>
</figure>
