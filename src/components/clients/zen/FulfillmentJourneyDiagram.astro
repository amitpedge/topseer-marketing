---
/** Loop 1 — end-to-end sequence and profile-to-artefact links */
---

<figure class="client-flow-diagram" aria-labelledby="fulfillment-journey-title">
  <figcaption id="fulfillment-journey-title" class="client-flow-diagram__caption">
    Phase 1 journey — from discovery to Zen report delivery
  </figcaption>
  <svg viewBox="0 0 920 360" fill="none" xmlns="http://www.w3.org/2000/svg" role="img">
    <defs>
      <marker id="fj-arrow" markerWidth="8" markerHeight="8" refX="6" refY="4" orient="auto">
        <path d="M0 0 L8 4 L0 8 Z" fill="#5E7C7B" />
      </marker>
    </defs>

    <rect x="16" y="16" width="888" height="148" rx="12" fill="#E6EDEC" stroke="#DED9CC" />
    <text x="32" y="42" fill="#5E7C7B" font-family="Barlow, sans-serif" font-size="11" font-weight="700" letter-spacing="1.5">BEFORE FIRST ORDER</text>

    <rect x="32" y="58" width="118" height="88" rx="10" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="91" y="88" text-anchor="middle" fill="#B87333" font-family="Barlow, sans-serif" font-size="10" font-weight="700">STEP 1</text>
    <text x="91" y="108" text-anchor="middle" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="13" font-weight="700">Discover</text>
    <text x="91" y="128" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="11">Browse packages</text>

    <line x1="150" y1="102" x2="178" y2="102" stroke="#5E7C7B" stroke-width="2" marker-end="url(#fj-arrow)" />

    <rect x="178" y="58" width="148" height="88" rx="10" fill="#1F3A3D" />
    <text x="252" y="88" text-anchor="middle" fill="#B87333" font-family="Barlow, sans-serif" font-size="10" font-weight="700">STEP 2</text>
    <text x="252" y="108" text-anchor="middle" fill="#F7F0DD" font-family="Barlow, sans-serif" font-size="13" font-weight="700">Sign up &amp; UHID</text>
    <text x="252" y="128" text-anchor="middle" fill="#F7F0DD" font-family="Barlow, sans-serif" font-size="11" opacity="0.8">Patient profile created</text>

    <rect x="16" y="188" width="888" height="156" rx="12" fill="#F7F0DD" stroke="#B87333" stroke-width="1.25" />
    <text x="32" y="214" fill="#B87333" font-family="Barlow, sans-serif" font-size="11" font-weight="700" letter-spacing="1.5">DIAGNOSTIC ORDER LIFECYCLE</text>

    <rect x="32" y="230" width="118" height="88" rx="10" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="91" y="260" text-anchor="middle" fill="#B87333" font-family="Barlow, sans-serif" font-size="10" font-weight="700">STEP 3</text>
    <text x="91" y="280" text-anchor="middle" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="13" font-weight="700">Book &amp; pay</text>
    <text x="91" y="300" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="11">Order + appointment</text>

    <line x1="150" y1="274" x2="178" y2="274" stroke="#5E7C7B" stroke-width="2" marker-end="url(#fj-arrow)" />

    <rect x="178" y="230" width="118" height="88" rx="10" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="237" y="260" text-anchor="middle" fill="#B87333" font-family="Barlow, sans-serif" font-size="10" font-weight="700">STEP 4</text>
    <text x="237" y="280" text-anchor="middle" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="13" font-weight="700">Test day</text>
    <text x="237" y="300" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="11">Check-in at lab</text>

    <line x1="296" y1="274" x2="324" y2="274" stroke="#5E7C7B" stroke-width="2" marker-end="url(#fj-arrow)" />

    <rect x="324" y="230" width="118" height="88" rx="10" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="383" y="260" text-anchor="middle" fill="#B87333" font-family="Barlow, sans-serif" font-size="10" font-weight="700">STEP 5</text>
    <text x="383" y="280" text-anchor="middle" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="13" font-weight="700">Wait</text>
    <text x="383" y="300" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="11">Report processing</text>

    <line x1="442" y1="274" x2="470" y2="274" stroke="#5E7C7B" stroke-width="2" marker-end="url(#fj-arrow)" />

    <rect x="470" y="230" width="168" height="88" rx="10" fill="#1F3A3D" />
    <text x="554" y="260" text-anchor="middle" fill="#B87333" font-family="Barlow, sans-serif" font-size="10" font-weight="700">STEP 6</text>
    <text x="554" y="280" text-anchor="middle" fill="#F7F0DD" font-family="Barlow, sans-serif" font-size="13" font-weight="700">Zen report delivered</text>
    <text x="554" y="300" text-anchor="middle" fill="#F7F0DD" font-family="Barlow, sans-serif" font-size="11" opacity="0.8">Visible in My orders</text>

    <path d="M252 146 L252 168 L91 168 L91 230" stroke="#5E7C7B" stroke-width="2" fill="none" marker-end="url(#fj-arrow)" />

    <rect x="660" y="58" width="228" height="286" rx="10" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="774" y="82" text-anchor="middle" fill="#5E7C7B" font-family="Barlow, sans-serif" font-size="11" font-weight="700" letter-spacing="1.2">PROFILE &amp; ARTEFACTS</text>

    <rect x="680" y="96" width="188" height="36" rx="8" fill="#E6EDEC" stroke="#DED9CC" />
    <text x="774" y="119" text-anchor="middle" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="12" font-weight="600">User</text>

    <line x1="774" y1="132" x2="774" y2="148" stroke="#5E7C7B" stroke-width="1.5" marker-end="url(#fj-arrow)" />

    <rect x="680" y="148" width="188" height="44" rx="8" fill="#1F3A3D" />
    <text x="774" y="168" text-anchor="middle" fill="#F7F0DD" font-family="Barlow, sans-serif" font-size="12" font-weight="700">Patient profile · UHID</text>
    <text x="774" y="184" text-anchor="middle" fill="#F7F0DD" font-family="Barlow, sans-serif" font-size="10" opacity="0.75">Permanent identifier</text>

    <line x1="774" y1="192" x2="774" y2="208" stroke="#5E7C7B" stroke-width="1.5" marker-end="url(#fj-arrow)" />

    <rect x="680" y="208" width="188" height="36" rx="8" fill="#F7F0DD" stroke="#B87333" />
    <text x="774" y="231" text-anchor="middle" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="12" font-weight="600">Diagnostic order</text>

    <line x1="720" y1="244" x2="720" y2="262" stroke="#5E7C7B" stroke-width="1.5" marker-end="url(#fj-arrow)" />
    <line x1="828" y1="244" x2="828" y2="262" stroke="#5E7C7B" stroke-width="1.5" marker-end="url(#fj-arrow)" />

    <rect x="680" y="262" width="88" height="34" rx="8" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="724" y="284" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="10" font-weight="600">Appointment</text>

    <rect x="780" y="262" width="88" height="34" rx="8" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="824" y="284" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="10" font-weight="600">Zen report</text>

    <rect x="680" y="306" width="188" height="28" rx="8" fill="#E6EDEC" stroke="#DED9CC" />
    <text x="774" y="325" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="10">Payment profile pays order</text>
  </svg>
</figure>
