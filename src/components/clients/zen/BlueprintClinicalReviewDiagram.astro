        <path d="M0 0 L8 4 L0 8 Z" fill="#C8613A" />
      </marker>
    </defs>

    <text x="16" y="28" fill="#5E7C7B" font-family="Barlow, sans-serif" font-size="11" font-weight="700" letter-spacing="1.5">PHYSICIAN WORKFLOW · HUMAN + AI</text>

    <rect x="16" y="44" width="96" height="48" rx="10" fill="#E6EDEC" stroke="#DED9CC" />
