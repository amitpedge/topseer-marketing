---
/** Platform + Pantry architecture diagram — petrol / cream / rust palette */
---

<div class="platform-diagram" aria-hidden="true">
  <svg viewBox="0 0 960 280" fill="none" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <marker id="arrow" markerWidth="8" markerHeight="8" refX="6" refY="4" orient="auto">
        <path d="M0 0 L8 4 L0 8 Z" fill="#5E7C7B" />
      </marker>
    </defs>

    <rect x="20" y="90" width="200" height="120" rx="12" fill="#E6EDEC" stroke="#DED9CC" />
    <text x="120" y="125" text-anchor="middle" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="14" font-weight="700">Your systems</text>
    <text x="120" y="150" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="12">ERP · CRM · HRIS</text>
    <text x="120" y="170" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="12">Slack · ServiceNow</text>

    <line x1="220" y1="150" x2="290" y2="150" stroke="#5E7C7B" stroke-width="2" marker-end="url(#arrow)" />

    <rect x="290" y="70" width="260" height="160" rx="12" fill="#1F3A3D" />
    <text x="420" y="108" text-anchor="middle" fill="#F7F0DD" font-family="Barlow, sans-serif" font-size="13" font-weight="700" letter-spacing="2">TOPSEER PLATFORM</text>
    <text x="420" y="138" text-anchor="middle" fill="#B87333" font-family="Barlow, sans-serif" font-size="11" font-weight="700" letter-spacing="1.5">CONNECTORS</text>
    <text x="420" y="162" text-anchor="middle" fill="#F7F0DD" font-family="Barlow, sans-serif" font-size="11" opacity="0.75">Governance · Observability</text>
    <text x="420" y="182" text-anchor="middle" fill="#F7F0DD" font-family="Barlow, sans-serif" font-size="11" opacity="0.75">Deploy anywhere · VPC</text>
    <text x="420" y="210" text-anchor="middle" fill="#5E7C7B" font-family="Barlow, sans-serif" font-size="11">Version-pinned releases</text>

    <line x1="550" y1="150" x2="620" y2="150" stroke="#5E7C7B" stroke-width="2" marker-end="url(#arrow)" />

    <rect x="620" y="90" width="200" height="120" rx="12" fill="#F7F0DD" stroke="#B87333" stroke-width="1.5" />
    <text x="720" y="125" text-anchor="middle" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="14" font-weight="700">Agent Pantry</text>
    <text x="720" y="150" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="12">Pre-cooked agents</text>
    <text x="720" y="175" text-anchor="middle" fill="#C8613A" font-family="JetBrains Mono, monospace" font-size="11">frozen@v1</text>

    <line x1="820" y1="150" x2="890" y2="150" stroke="#5E7C7B" stroke-width="2" marker-end="url(#arrow)" />

    <rect x="890" y="110" width="50" height="80" rx="10" fill="#FFFFFF" stroke="#DED9CC" />
    <text x="915" y="142" text-anchor="middle" fill="#1F3A3D" font-family="Barlow, sans-serif" font-size="10" font-weight="700">Teams</text>
    <text x="915" y="158" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="9">Chat</text>
    <text x="915" y="172" text-anchor="middle" fill="#6E7A78" font-family="Barlow, sans-serif" font-size="9">API</text>
  </svg>
</div>
