---
import "../styles/global.css";
import "../styles/marketing.css";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  author?: string;
  tags?: string[];
}

const {
  title,
  description = "Topseer builds pre-cooked AI agents for enterprise — frozen at the version you approve.",
  ogTitle,
  ogType = "website",
  publishedTime,
  author,
  tags = [],
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const origin = (Astro.site?.toString() ?? "https://topseer.tech/").replace(/\/$/, "");
const pageTitle = title.includes("Topseer") ? title : `${title} · Topseer`;

const organization = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Topseer",
  legalName: "Topseer Tech Private Limited",
  url: origin + "/",
  logo: origin + "/topseer-monogram.png",
  description,
};

const articleSchema =
  ogType === "article" && publishedTime
    ? {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: title,
        description,
        datePublished: publishedTime,
        author: {
          "@type": "Organization",
          name: author ?? "Topseer",
        },
        publisher: {
          "@type": "Organization",
          name: "Topseer",
          logo: {
            "@type": "ImageObject",
            url: origin + "/topseer-monogram.png",
          },
        },
        mainEntityOfPage: canonical.toString(),
        keywords: tags.join(", "),
      }
    : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/topseer-monogram.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Merriweather:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Topseer" />
    <meta property="og:title" content={ogTitle ?? pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {author && ogType === "article" && <meta property="article:author" content={author} />}
    {
      tags.map((tag) => (
        <meta property="article:tag" content={tag} />
      ))
    }
    <meta name="twitter:card" content="summary" />
    <script type="application/ld+json" set:html={JSON.stringify(organization)} />
    {articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}
  </head>
  <body>
    <div class="site">
      <SiteNav />
      <main>
        <slot />
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
